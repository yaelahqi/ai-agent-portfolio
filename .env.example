# AI Agent Portfolio - Environment Variables
# Copy this file to .env and fill in your API keys

# =====================
# AI Model API Keys
# =====================

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude 3.5, Claude 3, etc.)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google (Gemini Pro, Gemini Flash)
GOOGLE_API_KEY=your-google-api-key-here

# Groq (Mixtral, Llama, etc.)
GROQ_API_KEY=gsk_your-groq-api-key-here

# Xiaomi MiMo
XIAOMI_MIMO_API_KEY=your-mimo-api-key-here

# =====================
# Platform Tokens
# =====================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# =====================
# Optional Services
# =====================

# ElevenLabs (Voice Cloning)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# FAL (Image Generation)
FAL_API_KEY=your-fal-api-key-here

# =====================
# Trading APIs
# =====================

# IDX API (Indonesian Stock Exchange)
IDX_API_KEY=your-idx-api-key-here

# Ajaib API (Trading Platform)
AJAIB_API_KEY=your-ajaib-api-key-here

# =====================
# Configuration
# =====================

# Model Selection
DEFAULT_MODEL=gpt-4o
FALLBACK_MODEL=claude-3-5-sonnet-20241022

# OCR Language
OCR_LANGUAGE=eng+ind

# TTS Voice
TTS_VOICE=id-ID-ArdiNeural

# Trading Mode (simulation or live)
TRADING_MODE=simulation

# Capital for Trading (IDR)
TRADING_CAPITAL=100000000

# =====================
# Server Configuration
# =====================

# Server Port
PORT=8080

# WebSocket Port
WS_PORT=8081

# Log Level
LOG_LEVEL=INFO

# Enable Debug Mode
DEBUG=false
